[Unit]
Description=OnlySpecs Frontend Server
After=network.target onlyspecs-api.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/onlyspecs/api-integration
Environment="PORT=9000"
Environment="ONLYSPECS_API_URL=http://localhost:3580"
ExecStart=/usr/bin/python3 app.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
